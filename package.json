{
  "name": "qq-multi-bot",
  "version": "1.0.0",
  "description": "QQ多功能机器人系统 - Node.js全栈实现",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "gen:secret": "node -e \"console.log('JWT_SECRET=' + require('crypto').randomBytes(64).toString('hex'))\"",
    "db:init": "node scripts/init-db.js",
    "install:all": "npm install && cd web && npm install",
    "client:install": "cd web && npm install",
    "client:build": "cd web && npm run build",
    "client:dev": "cd web && npm run dev"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "msedge-tts": "^2.0.5",
    "mysql2": "^3.9.1",
    "sequelize": "^6.37.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
